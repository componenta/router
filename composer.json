{
    "name": "componenta/router",
    "description": "HTTP route registration, matching, generation, and compiled route cache for Componenta applications",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/arrayable": "^1.0",
        "componenta/config": "^1.0",
        "componenta/di": "^1.0",
        "componenta/http-responder": "^1.0",
        "componenta/middleware-factory": "^1.0",
        "componenta/path-resolver": "^1.0",
        "componenta/var-export": "^1.0",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Http\\Router\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\Http\\Router\\Tests\\": "tests/",
            "Componenta\\Http\\Router\\Benchmarks\\": "benchmarks/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Http\\Router\\ConfigProvider"
            ]
        }
    }
}
